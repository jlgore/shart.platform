{
  "name": "shart-platform-api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --persist-to=../.wrangler/state",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute shart-ctf-db --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute shart-ctf-db --local --file=./schema.sql",
    "db:seed": "wrangler d1 execute shart-ctf-db --file=./seed.sql",
    "db:seed:local": "wrangler d1 execute shart-ctf-db --local --file=./seed.sql"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.5",
    "better-auth": "^1.2.0",
    "hono": "^4.6.0",
    "kysely": "^0.27.0",
    "kysely-d1": "^0.3.0",
    "nanoid": "^5.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.59.1"
  }
}
