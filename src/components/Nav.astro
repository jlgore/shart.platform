---
/**
 * Main Navigation Component
 * Responsive nav with mobile hamburger menu
 */
import ThemeSwitcher from "./ThemeSwitcher.astro";
import type { SessionUser } from "../lib/auth";

interface Props {
  user?: SessionUser | null;
}

const { user } = Astro.props;

const navLinks = [
  { href: "/blog", label: "Blog" },
  { href: "/ctf", label: "CTF" },
  { href: "/courses", label: "Courses" },
  { href: "/games", label: "Games" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<nav class="nav" aria-label="Main navigation">
  <div class="nav-inner">
    <!-- Logo -->
    <a class="nav-brand" href="/" aria-label="SHART.CLOUD home">
      <span class="nav-brand-text">SHART</span><span class="nav-brand-dot">.</span><span class="nav-brand-text">CLOUD</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="nav-desktop">
      {navLinks.map(({ href, label }) => (
        <a
          class:list={["nav-link", { "nav-link-active": currentPath.startsWith(href) }]}
          href={href}
          aria-current={currentPath.startsWith(href) ? "page" : undefined}
        >
          {label}
        </a>
      ))}

      <!-- Auth section -->
      {user ? (
        <div class="nav-user">
          <span class="nav-user-name">{user.name || user.email}</span>
          <button type="button" class="nav-logout" id="logout-btn">Logout</button>
        </div>
      ) : (
        <a
          class:list={["nav-link", { "nav-link-active": currentPath.startsWith("/auth") }]}
          href="/auth/login"
        >
          Login
        </a>
      )}
    </div>

    <!-- Right side: Theme switcher + Mobile toggle -->
    <div class="nav-actions">
      <ThemeSwitcher />

      <!-- Mobile menu button -->
      <button
        type="button"
        class="nav-mobile-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="nav-mobile" aria-hidden="true">
    {navLinks.map(({ href, label }) => (
      <a
        class:list={["nav-mobile-link", { "nav-mobile-link-active": currentPath.startsWith(href) }]}
        href={href}
        aria-current={currentPath.startsWith(href) ? "page" : undefined}
      >
        {label}
      </a>
    ))}

    <!-- Auth section (mobile) -->
    <div class="nav-mobile-divider"></div>
    {user ? (
      <>
        <span class="nav-mobile-user">{user.name || user.email}</span>
        <button type="button" class="nav-mobile-link nav-mobile-logout" id="logout-btn-mobile">
          Logout
        </button>
      </>
    ) : (
      <a
        class:list={["nav-mobile-link", { "nav-mobile-link-active": currentPath.startsWith("/auth") }]}
        href="/auth/login"
      >
        Login
      </a>
    )}
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background-color: var(--color-bg);
    border-bottom: none;
    background-image: linear-gradient(to right, transparent, var(--color-border), transparent);
    background-size: 100% 1px;
    background-position: bottom;
    background-repeat: no-repeat;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
    height: 3.5rem;
  }

  @media (min-width: 640px) {
    .nav-inner {
      padding: 0 1.5rem;
    }
  }

  /* Brand */
  .nav-brand {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 1.125rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--color-primary);
    transition: color 0.15s;
  }

  .nav-brand:hover {
    color: var(--color-primary-bright);
  }

  .nav-brand-dot {
    color: var(--color-primary-bright);
  }

  /* Desktop nav */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    position: relative;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-primary-muted);
    padding: 0.5rem 0;
    transition: color 0.15s;
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  .nav-link-active {
    color: var(--color-primary);
  }

  .nav-link-active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background-color: var(--color-accent);
  }

  /* Actions (theme + mobile toggle) */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Mobile toggle */
  .nav-mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 2rem;
    height: 2rem;
    padding: 0.25rem;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  .nav-mobile-toggle:hover {
    border-color: var(--color-primary);
  }

  @media (min-width: 640px) {
    .nav-mobile-toggle {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    transition: transform 0.2s, opacity 0.2s;
  }

  /* Hamburger animation when open */
  .nav-mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .nav-mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .nav-mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile menu */
  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 1rem;
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
  }

  .nav-mobile.open {
    display: flex;
  }

  @media (min-width: 640px) {
    .nav-mobile {
      display: none !important;
    }
  }

  .nav-mobile-link {
    padding: 0.75rem 1rem;
    font-size: 1rem;
    text-decoration: none;
    color: var(--color-primary-muted);
    border-radius: 0.25rem;
    transition: background-color 0.15s, color 0.15s;
  }

  .nav-mobile-link:hover {
    background-color: var(--color-border);
    color: var(--color-primary);
  }

  .nav-mobile-link-active {
    color: var(--color-primary);
    background-color: var(--color-border);
  }

  .nav-mobile-divider {
    height: 1px;
    background-color: var(--color-border);
    margin: 0.5rem 0;
  }

  .nav-mobile-user {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: var(--color-primary-subtle);
  }

  .nav-mobile-logout {
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    width: 100%;
    color: var(--color-error);
  }

  /* Desktop auth styles */
  .nav-user {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-user-name {
    font-size: 0.875rem;
    color: var(--color-primary-subtle);
  }

  .nav-logout {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: var(--color-primary-muted);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }

  .nav-logout:hover {
    border-color: var(--color-error);
    color: var(--color-error);
  }
</style>

<script>
  function initMobileNav() {
    const toggle = document.querySelector('.nav-mobile-toggle');
    const menu = document.getElementById('mobile-menu');

    if (!toggle || !menu) return;

    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.contains('open');
      menu.classList.toggle('open');
      menu.setAttribute('aria-hidden', String(isOpen));
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('open')) {
        menu.classList.remove('open');
        menu.setAttribute('aria-hidden', 'true');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });

    // Close when clicking a link
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.remove('open');
        menu.setAttribute('aria-hidden', 'true');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }

  function initLogout() {
    const handleLogout = async () => {
      try {
        await fetch('/api/auth/sign-out', {
          method: 'POST',
          credentials: 'include',
        });
        window.location.href = '/';
      } catch (e) {
        console.error('Logout failed:', e);
        window.location.href = '/';
      }
    };

    document.getElementById('logout-btn')?.addEventListener('click', handleLogout);
    document.getElementById('logout-btn-mobile')?.addEventListener('click', handleLogout);
  }

  initMobileNav();
  initLogout();
  document.addEventListener('astro:after-swap', () => {
    initMobileNav();
    initLogout();
  });
</script>
