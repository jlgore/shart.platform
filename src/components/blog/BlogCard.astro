---
import type { CollectionEntry } from 'astro:content';
import DataCard from '../ui/DataCard.astro';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, category, tags, readTime } = post.data;
const isLinkPost = post.data.isLinkPost === true && typeof post.data.externalLink === 'string';
const href = isLinkPost ? post.data.externalLink! : `/blog/${post.slug}`;

const categoryLabels: Record<string, string> = {
  'cloud-security': 'Security',
  'ctf-writeups': 'CTF',
  'tutorials': 'Tutorial',
  'rants': 'Rant'
};
---

<DataCard as="article" class="blog-card" noPad>
  <a href={href} class="blog-card-link" target={isLinkPost ? '_blank' : undefined} rel={isLinkPost ? 'noopener noreferrer' : undefined}>
    <!-- Header: Category + Date -->
    <div class="blog-card-meta">
      <span class="blog-card-category">{categoryLabels[category]}</span>
      <span class="blog-card-dot" aria-hidden="true"></span>
      <time datetime={date.toISOString()} class="blog-card-date">
        {new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </time>
      {!isLinkPost && (
        <>
          <span class="blog-card-dot" aria-hidden="true"></span>
          <span class="blog-card-reading-time">{readTime} min</span>
        </>
      )}
      {isLinkPost && (
        <span class="blog-card-external">External</span>
      )}
    </div>

    <!-- Title -->
    <h3 class="blog-card-title">
      {title}
      {isLinkPost && <span class="blog-card-arrow" aria-hidden="true">↗</span>}
    </h3>

    <!-- Description -->
    <p class="blog-card-description">{description}</p>

    <!-- Footer: Tags -->
    {tags.length > 0 && (
      <div class="blog-card-tags">
        {tags.slice(0, 3).map((tag) => (
          <span class="blog-card-tag">#{tag}</span>
        ))}
        {tags.length > 3 && (
          <span class="blog-card-tag-more">+{tags.length - 3}</span>
        )}
      </div>
    )}
  </a>
</DataCard>

<style>
  .blog-card {
    animation: card-enter 0.45s cubic-bezier(0.22, 1, 0.36, 1) backwards;
  }

  @keyframes card-enter {
    from {
      opacity: 0;
      transform: translateY(10px);
      filter: blur(1px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .blog-card-link {
    display: block;
    padding: 1.5rem;
    text-decoration: none;
    border-radius: inherit;
    transition: background-color 0.2s ease;
  }

  .blog-card-link:hover {
    background-color: color-mix(in srgb, var(--color-bg-elevated) 60%, var(--color-border) 40%);
  }

  /* Meta row */
  .blog-card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .blog-card-category {
    color: var(--color-accent);
    font-weight: 600;
  }

  .blog-card-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background-color: var(--color-primary-subtle);
  }

  .blog-card-date,
  .blog-card-reading-time {
    color: var(--color-primary-subtle);
  }

  .blog-card-external {
    margin-left: auto;
    padding: 0.125rem 0.5rem;
    font-size: 0.625rem;
    color: var(--color-primary-subtle);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
  }

  /* Title */
  .blog-card-title {
    margin: 0 0 0.625rem;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-primary);
    transition: color 0.15s;
  }

  .blog-card-link:hover .blog-card-title {
    color: var(--color-primary-bright);
  }

  .blog-card-arrow {
    margin-left: 0.25rem;
    color: var(--color-primary-subtle);
  }

  /* Description */
  .blog-card-description {
    margin: 0 0 1rem;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--color-primary-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Tags */
  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .blog-card-tag {
    font-size: 0.75rem;
    color: var(--color-primary-subtle);
  }

  .blog-card-tag-more {
    font-size: 0.75rem;
    color: var(--color-primary-subtle);
    opacity: 0.7;
  }
</style>
