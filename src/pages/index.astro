---
import BaseLayout from '../layouts/BaseLayout.astro';
import LazyLatestActivity from '../components/LazyLatestActivity.astro';
import UpcomingEvents from '../components/events/UpcomingEvents.astro';
---

<BaseLayout title="Home">
  <section class="mb-10">
    <h1 class="text-3xl font-bold text-term-green uppercase">SHART.CLOUD</h1>
    <p class="text-term-green/80 mt-2">Cloud security education done in a 💩 way.</p>

    <div class="mt-4 flex gap-4 text-sm">
      <a class="navbar-link" href="/ctf">CTFs</a>
      <a class="navbar-link" href="/labs">Labs</a>
      <a class="navbar-link" href="/blog">Blog</a>
    </div>
  </section>

  <UpcomingEvents limit={1} title="Upcoming events" />


  <LazyLatestActivity limit={6} include={["blog", "labs"]} />
</BaseLayout>
