---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

const user = Astro.locals.user;

// Redirect if already logged in
if (user) {
  return Astro.redirect('/');
}

const rawError = Astro.url.searchParams.get('error');
const allowedErrors = ['Passwords do not match', 'Registration failed', 'Connection failed'];
const error = rawError && allowedErrors.includes(rawError) ? rawError : null;
---

<BaseLayout title="Register">
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-header">
        <div class="auth-icon">&#128100;</div>
        <h1 class="auth-title">Create Account</h1>
        <p class="auth-subtitle">Join the SHART.CLOUD platform</p>
      </div>

      <div class="auth-terminal">
        <div class="terminal-bar">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-path">~/auth/register</span>
        </div>

        {error && (
          <div class="auth-message auth-message-error">
            <span class="message-prefix">[ERR]</span> {error}
          </div>
        )}

        <form id="register-form" class="auth-form">
          <div class="form-group">
            <label for="name" class="form-label">
              <span class="label-prompt">$</span> DISPLAY NAME
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="form-input"
              placeholder="h4ck3r"
            />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">
              <span class="label-prompt">$</span> EMAIL
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="form-input"
              placeholder="user@example.com"
            />
          </div>

          <div class="form-group">
            <label for="password" class="form-label">
              <span class="label-prompt">$</span> PASSWORD
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="8"
              autocomplete="new-password"
              class="form-input"
              placeholder="********"
            />
            <p class="form-hint">Minimum 8 characters</p>
          </div>

          <div class="form-group">
            <label for="confirm-password" class="form-label">
              <span class="label-prompt">$</span> CONFIRM PASSWORD
            </label>
            <input
              type="password"
              id="confirm-password"
              name="confirmPassword"
              required
              minlength="8"
              autocomplete="new-password"
              class="form-input"
              placeholder="********"
            />
          </div>

          <button type="submit" class="auth-submit">
            <span class="submit-text">CREATE ACCOUNT</span>
            <span class="submit-arrow">→</span>
          </button>
        </form>

        <div class="auth-footer">
          <span class="footer-text">Already have an account?</span>
          <a href="/auth/login" class="footer-link">Log in</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const confirmPassword = formData.get('confirmPassword') as string;

    if (password !== confirmPassword) {
      window.location.href = '/auth/register?error=Passwords%20do%20not%20match';
      return;
    }

    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = button.querySelector('.submit-text')?.textContent;
    const submitText = button.querySelector('.submit-text');
    if (submitText) submitText.textContent = 'CREATING...';
    button.disabled = true;

    try {
      const res = await fetch('/api/auth/sign-up/email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, password }),
        credentials: 'include',
      });

      if (res.ok) {
        window.location.href = '/auth/login?registered=1';
      } else {
        window.location.href = '/auth/register?error=Registration%20failed';
      }
    } catch (err) {
      window.location.href = '/auth/register?error=Connection%20failed';
    } finally {
      if (submitText && originalText) submitText.textContent = originalText;
      button.disabled = false;
    }
  });
</script>

<style>
  .auth-container {
    display: flex;
    justify-content: center;
    padding: 2rem 0;
  }

  .auth-card {
    width: 100%;
    max-width: 420px;
  }

  .auth-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .auth-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .auth-title {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .auth-subtitle {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-primary-muted);
  }

  .auth-terminal {
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-primary-subtle);
  }

  .terminal-dot:first-child {
    background-color: #ff5f56;
  }

  .terminal-dot:nth-child(2) {
    background-color: #ffbd2e;
  }

  .terminal-dot:nth-child(3) {
    background-color: #27ca40;
  }

  .terminal-path {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--color-primary-subtle);
    font-family: monospace;
  }

  .auth-message {
    margin: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: monospace;
  }

  .auth-message-error {
    background-color: color-mix(in srgb, var(--color-error) 10%, transparent);
    border: 1px solid var(--color-error);
    color: var(--color-error);
  }

  .message-prefix {
    font-weight: 700;
  }

  .auth-form {
    padding: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-muted);
  }

  .label-prompt {
    color: var(--color-accent);
    margin-right: 0.25rem;
  }

  .form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-family: monospace;
    font-size: 0.9375rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: var(--color-primary);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .form-input::placeholder {
    color: var(--color-primary-subtle);
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  .form-hint {
    margin: 0.25rem 0 0;
    font-size: 0.75rem;
    color: var(--color-primary-subtle);
  }

  .auth-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.875rem 1.5rem;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background-color: var(--color-primary);
    border: none;
    border-radius: 0.25rem;
    color: var(--color-bg);
    cursor: pointer;
    transition: all 0.15s;
  }

  .auth-submit:hover:not(:disabled) {
    background-color: var(--color-primary-bright);
    transform: translateY(-1px);
  }

  .auth-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .submit-arrow {
    transition: transform 0.15s;
  }

  .auth-submit:hover:not(:disabled) .submit-arrow {
    transform: translateX(3px);
  }

  .auth-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.875rem;
  }

  .footer-text {
    color: var(--color-primary-subtle);
    margin-right: 0.5rem;
  }

  .footer-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.15s;
  }

  .footer-link:hover {
    color: var(--color-primary-bright);
  }
</style>
