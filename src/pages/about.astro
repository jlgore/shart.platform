---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const bios = await getCollection('bios');
const sortedBios = bios.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="About">
  <h1 class="text-2xl font-bold text-theme-primary uppercase">About Us</h1>

  <p class="text-theme-muted mt-2 mb-8">Meet the team behind SHART.CLOUD.</p>

  <div class="grid gap-6 sm:grid-cols-2">
    {sortedBios.map((person) => (
      <section class="terminal-window">
        {person.data.image && (
          <img class="mb-3 rounded" src={person.data.image} alt={`Photo of ${person.data.name}`} width="200" loading="lazy" />
        )}
        <h2 class="text-lg font-bold">{person.data.name}</h2>
        <p class="text-sm text-theme-muted mb-3">{person.data.role}</p>
        <p class="mb-4 text-theme-muted">{person.data.bio}</p>

        <nav class="text-sm" aria-label={`${person.data.name}'s social links`}>
          {person.data.bluesky && (
            <>
              <a class="hover:text-theme-bright" href={`https://bsky.app/profile/${person.data.bluesky}`}>Bluesky</a>
              {(person.data.github || person.data.website) && <span class="text-theme-subtle" aria-hidden="true"> | </span>}
            </>
          )}
          {person.data.github && (
            <>
              <a class="hover:text-theme-bright" href={`https://github.com/${person.data.github}`}>GitHub</a>
              {person.data.website && <span class="text-theme-subtle" aria-hidden="true"> | </span>}
            </>
          )}
          {person.data.website && (
            <a class="hover:text-theme-bright" href={person.data.website}>Website</a>
          )}
        </nav>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  /* Reset global h2 mt-8 inside team cards — the card's p-6 already provides top spacing */
  section.terminal-window h2 {
    margin-top: 0;
  }

  /* Give social link row a little breathing room from the card bottom edge */
  section.terminal-window nav {
    padding-bottom: 0.25rem;
  }
</style>
