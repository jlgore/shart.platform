---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DataCard from '../components/ui/DataCard.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import FilterPill from '../components/ui/FilterPill.astro';

const labs = await getCollection('labs', ({ data }) => data.draft !== true);

const sortedLabs = labs.sort((a, b) =>
  new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime()
);

const categories = [...new Set(labs.map(lab => lab.data.category))].sort();
const difficulties = ['beginner', 'intermediate', 'advanced'];

const difficultySymbols: Record<string, string> = {
  beginner: '●○○',
  intermediate: '●●○',
  advanced: '●●●'
};
---

<BaseLayout
  title="Security Labs"
  description="Hands-on security labs covering cloud security, IAM, and infrastructure security topics."
>
  <div class="labs-page">
    <!-- Header -->
    <DataCard as="header" class="labs-header" hover={false} style="--card-padding: 1.75rem">
      <div class="labs-header__top">
        <span class="labs-header__prompt">[LAB_SYS]</span>
        <span class="labs-header__status">ONLINE</span>
      </div>
      <h1 class="labs-header__title">SECURITY_LABS</h1>
      <p class="labs-header__desc">
        Hands-on training modules with progressive difficulty. Each lab links to a GitHub repository
        with step-by-step branches. Clone, follow along, break things.
      </p>
      <div class="labs-header__stats">
        <span>{sortedLabs.length} LABS AVAILABLE</span>
        <span class="labs-header__divider">|</span>
        <span>{categories.length} CATEGORIES</span>
      </div>
    </DataCard>

    <!-- Filters -->
    <DataCard as="section" class="labs-filters" hover={false} style="--card-padding: 1rem 1.25rem">
      <div class="labs-filters__row">
        <span class="labs-filters__label">[FILTER]</span>

        <div class="labs-filters__group">
          {categories.map(category => (
            <FilterPill
              class="labs-filters__btn"
              data-filter="category"
              data-value={category}
            >
              {category.replace('-', '_').toUpperCase()}
            </FilterPill>
          ))}
        </div>

        <div class="labs-filters__group">
          {difficulties.map(difficulty => (
            <FilterPill
              class="labs-filters__btn labs-filters__btn--difficulty"
              tone="accent"
              data-filter="difficulty"
              data-value={difficulty}
            >
              <span class="labs-filters__diff-icon">{difficultySymbols[difficulty]}</span>
              {difficulty.toUpperCase()}
            </FilterPill>
          ))}
        </div>

        <FilterPill class="labs-filters__btn labs-filters__btn--clear" id="clear-filters" tone="danger">
          CLEAR
        </FilterPill>
      </div>
    </DataCard>

    <SectionHeader title="Training Modules" description="Select a lab to start a guided branch-by-branch walkthrough." />

    <!-- Labs Grid -->
    <section class="labs-grid">
      {sortedLabs.map((lab, index) => {
        const publishDate = lab.data.publishedDate.toLocaleDateString(undefined, {
          year: 'numeric', month: 'short', day: 'numeric'
        });

        return (
          <DataCard
            as="article"
            class="lab-card"
            data-category={lab.data.category}
            data-difficulty={lab.data.difficulty}
            style={`--delay: ${index * 50}ms; --card-padding: 1.5rem`}
          >
            <div class="lab-card__header">
              <div class="lab-card__meta">
                <span class="lab-card__id">LAB_{String(index + 1).padStart(3, '0')}</span>
                <span class="lab-card__difficulty" data-level={lab.data.difficulty}>
                  {difficultySymbols[lab.data.difficulty]}
                </span>
              </div>
              <span class="lab-card__category">[{lab.data.category.replace('-', '_').toUpperCase()}]</span>
            </div>

            <h2 class="lab-card__title">
              <a href={`/labs/${lab.slug}`}>{lab.data.title}</a>
            </h2>

            <p class="lab-card__desc">{lab.data.description}</p>

            <div class="lab-card__objectives">
              <span class="lab-card__objectives-label">OBJECTIVES:</span>
              <ul class="lab-card__objectives-list">
                {lab.data.learningObjectives.slice(0, 2).map(obj => (
                  <li>{obj}</li>
                ))}
                {lab.data.learningObjectives.length > 2 && (
                  <li class="lab-card__more">+{lab.data.learningObjectives.length - 2} more</li>
                )}
              </ul>
            </div>

            <div class="lab-card__tags">
              {lab.data.tags.slice(0, 4).map(tag => (
                <span class="lab-card__tag">#{tag}</span>
              ))}
            </div>

            <div class="lab-card__footer">
              <div class="lab-card__time">
                <span class="lab-card__time-icon">◷</span>
                ~{lab.data.estimatedTime}min
              </div>
              <a
                href={`https://github.com/${lab.data.githubRepo}`}
                target="_blank"
                rel="noopener noreferrer"
                class="lab-card__repo"
              >
                REPO ↗
              </a>
              <time datetime={lab.data.publishedDate.toISOString()} class="lab-card__date">
                {publishDate}
              </time>
            </div>

            <a href={`/labs/${lab.slug}`} class="lab-card__link" aria-label={`Start ${lab.data.title}`}>
              <span class="lab-card__link-text">ENTER LAB</span>
              <span class="lab-card__link-arrow">→</span>
            </a>
          </DataCard>
        );
      })}
    </section>

    {sortedLabs.length === 0 && (
      <div class="labs-empty">
        <span class="labs-empty__icon">○</span>
        <p>NO LABS AVAILABLE</p>
        <p class="labs-empty__sub">Check back soon for new training modules.</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .labs-page {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  /* Header */
  .labs-header {
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 6%, transparent), transparent 48%),
      var(--color-bg-elevated);
  }

  .labs-header__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }

  .labs-header__prompt {
    color: var(--color-accent);
    font-weight: 700;
  }

  .labs-header__status {
    color: var(--color-primary);
    animation: breathe 4s ease-in-out infinite;
  }

  .labs-header__title {
    font-size: clamp(1.65rem, 2.2vw, 2rem);
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.05em;
    margin: 0 0 0.75rem;
  }

  .labs-header__desc {
    font-size: 0.875rem;
    color: var(--color-primary-muted);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0 0 1rem;
  }

  .labs-header__stats {
    display: flex;
    gap: 0.75rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary-subtle);
  }

  .labs-header__divider {
    opacity: 0.4;
  }

  /* Filters */
  .labs-filters {
    background: color-mix(in srgb, var(--color-bg) 90%, var(--color-bg-elevated));
  }

  .labs-filters__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .labs-filters__label {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .labs-filters__group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .labs-filters__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.625rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary-muted);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.15s;
  }

  .labs-filters__btn:hover {
    border-color: var(--color-primary-muted);
    color: var(--color-primary);
  }

  .labs-filters__btn.active {
    background: color-mix(in srgb, var(--color-primary) 15%, var(--color-bg));
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .labs-filters__btn--difficulty.active {
    background: color-mix(in srgb, var(--color-accent) 15%, var(--color-bg));
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .labs-filters__diff-icon {
    font-size: 0.5rem;
    letter-spacing: 1px;
  }

  .labs-filters__btn--clear {
    margin-left: auto;
    color: var(--color-primary-subtle);
    border-color: transparent;
  }

  .labs-filters__btn--clear:hover {
    color: var(--color-error);
    border-color: var(--color-error);
  }

  /* Labs Grid */
  .labs-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .labs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .labs-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Lab Card */
  .lab-card {
    position: relative;
    display: flex;
    flex-direction: column;
    animation: card-enter 0.45s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    animation-delay: var(--delay);
  }

  @keyframes card-enter {
    from {
      opacity: 0;
      transform: translateY(12px);
      filter: blur(1px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .lab-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .lab-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lab-card__id {
    font-size: 0.5625rem;
    font-weight: 700;
    color: var(--color-primary-subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .lab-card__difficulty {
    font-size: 0.5rem;
    letter-spacing: 2px;
    color: var(--color-accent);
  }

  .lab-card__difficulty[data-level="beginner"] {
    color: var(--color-primary);
  }

  .lab-card__difficulty[data-level="advanced"] {
    color: var(--color-error);
  }

  .lab-card__category {
    font-size: 0.5625rem;
    color: var(--color-primary-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .lab-card__title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.5rem;
  }

  .lab-card__title a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .lab-card__title a:hover {
    color: var(--color-primary-bright);
  }

  .lab-card__desc {
    font-size: 0.8125rem;
    color: var(--color-primary-muted);
    line-height: 1.5;
    margin: 0 0 1rem;
    flex-grow: 1;
  }

  .lab-card__objectives {
    margin-bottom: 0.75rem;
  }

  .lab-card__objectives-label {
    display: block;
    font-size: 0.5625rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.375rem;
  }

  .lab-card__objectives-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.6875rem;
    line-height: 1.5;
    color: var(--color-primary-subtle);
  }

  .lab-card__objectives-list li {
    margin-bottom: 0.125rem;
  }

  .lab-card__objectives-list li::before {
    content: '→ ';
    color: var(--color-border);
  }

  .lab-card__more {
    color: var(--color-primary-muted);
    font-style: italic;
  }

  .lab-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1rem;
  }

  .lab-card__tag {
    font-size: 0.5625rem;
    color: var(--color-primary-subtle);
    padding: 0.125rem 0.375rem;
    border: 1px solid var(--color-border);
    border-radius: 2px;
  }

  .lab-card__footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary-subtle);
  }

  .lab-card__time {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .lab-card__time-icon {
    font-size: 0.75rem;
  }

  .lab-card__repo {
    color: var(--color-primary-muted);
    text-decoration: none;
  }

  .lab-card__repo:hover {
    color: var(--color-primary);
  }

  .lab-card__date {
    margin-left: auto;
  }

  .lab-card__link {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    background: var(--color-bg);
    border: 1px solid var(--color-primary-muted);
    border-radius: 2px;
    text-decoration: none;
    transition: all 0.2s ease;
    opacity: 0;
    transform: translateX(8px);
  }

  .lab-card:hover .lab-card__link {
    opacity: 1;
    transform: translateX(0);
  }

  .lab-card__link:hover {
    background: color-mix(in srgb, var(--color-primary) 15%, var(--color-bg));
    border-color: var(--color-primary);
  }

  .lab-card__link-arrow {
    transition: transform 0.15s;
  }

  .lab-card__link:hover .lab-card__link-arrow {
    transform: translateX(2px);
  }

  @media (max-width: 900px) {
    .lab-card__link {
      position: static;
      margin-top: 0.875rem;
      margin-left: auto;
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Empty State */
  .labs-empty {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-primary-subtle);
  }

  .labs-empty__icon {
    display: block;
    font-size: 2rem;
    margin-bottom: 1rem;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .labs-empty__sub {
    font-size: 0.75rem;
    margin-top: 0.5rem;
  }

  /* Hidden state for filtering */
  .lab-card[data-hidden="true"] {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.labs-filters__btn[data-filter]');
    const clearButton = document.getElementById('clear-filters');
    const labCards = document.querySelectorAll('.lab-card');

    const activeFilters: Record<string, Set<string>> = {
      category: new Set(),
      difficulty: new Set()
    };

    function updateDisplay() {
      labCards.forEach(card => {
        const el = card as HTMLElement;
        const category = el.dataset.category || '';
        const difficulty = el.dataset.difficulty || '';

        const categoryMatch = activeFilters.category.size === 0 || activeFilters.category.has(category);
        const difficultyMatch = activeFilters.difficulty.size === 0 || activeFilters.difficulty.has(difficulty);

        el.dataset.hidden = String(!(categoryMatch && difficultyMatch));
      });
    }

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filterType = button.getAttribute('data-filter')!;
        const value = button.getAttribute('data-value')!;

        if (activeFilters[filterType].has(value)) {
          activeFilters[filterType].delete(value);
          button.classList.remove('active');
        } else {
          activeFilters[filterType].add(value);
          button.classList.add('active');
        }

        updateDisplay();
      });
    });

    clearButton?.addEventListener('click', () => {
      activeFilters.category.clear();
      activeFilters.difficulty.clear();
      filterButtons.forEach(btn => btn.classList.remove('active'));
      updateDisplay();
    });
  });
</script>
