---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import DataCard from '../../components/ui/DataCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['all', 'cloud-security', 'ctf-writeups', 'tutorials', 'rants'];
const currentCategory = Astro.url.searchParams.get('category') || 'all';

const filteredPosts = currentCategory === 'all' 
  ? posts 
  : posts.filter(post => post.data.category === currentCategory);
---

<BaseLayout title="Blog" description="Cloud security insights, CTF writeups, and irreverent takes on the industry">
  <!-- Header -->
  <SectionHeader
    title="Blog"
    description="Cloud security insights, CTF writeups, and irreverent takes on the industry."
    class="blog-header"
  />

  <!-- Category Filter -->
  <DataCard as="section" class="blog-filter-wrap" hover={false} style="--card-padding: 0.875rem 1.125rem">
    <nav class="category-filter" aria-label="Filter by category">
      {categories.map((category) => (
        <a
          href={category === 'all' ? '/blog' : `/blog?category=${category}`}
          class:list={["filter-btn", { "filter-btn-active": currentCategory === category }]}
          aria-current={currentCategory === category ? 'page' : undefined}
        >
          {category === 'all' ? 'All' : category.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())}
        </a>
      ))}
    </nav>
  </DataCard>

  <!-- Posts Grid -->
  {filteredPosts.length === 0 ? (
    <div class="empty-state">
      <p>
        {currentCategory !== 'all' ? (
          <>No posts found in category: {currentCategory.replace('-', ' ')}</>
        ) : (
          "No posts available yet."
        )}
      </p>
      {currentCategory !== 'all' && (
        <a href="/blog" class="empty-state-link">View all posts</a>
      )}
    </div>
  ) : (
    <div class="posts-grid">
      {filteredPosts.map((post) => (
        <BlogCard post={post} />
      ))}
    </div>
  )}
</BaseLayout>

<style>
  .blog-header {
    margin-bottom: 1.25rem;
  }

  .blog-filter-wrap {
    margin-bottom: 1.5rem;
    background: color-mix(in srgb, var(--color-bg) 90%, var(--color-bg-elevated));
  }

  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .filter-btn {
    padding: 0.4rem 0.75rem;
    font-size: 0.6875rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    border: 1px solid var(--color-border);
    color: var(--color-primary-muted);
    transition: border-color 0.15s, color 0.15s, background-color 0.15s;
  }

  .filter-btn:hover {
    border-color: var(--color-primary-subtle);
    color: var(--color-primary);
  }

  .filter-btn-active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-bg);
  }

  .filter-btn-active:hover {
    background-color: var(--color-primary-bright);
    border-color: var(--color-primary-bright);
    color: var(--color-bg);
  }

  .posts-grid {
    display: grid;
    gap: 1.3rem;
  }

  @media (min-width: 768px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-primary-muted);
    border: 1px dashed var(--color-border);
    border-radius: 0.5rem;
  }

  .empty-state p {
    margin-bottom: 1rem;
  }

  .empty-state-link {
    color: var(--color-primary);
  }
</style>
