---
import BaseLayout from './BaseLayout.astro';
import { type CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, author, category, tags, readTime } = post.data;
// Absolute OG image URL for this post
const siteOrigin = (Astro.site as any)?.origin || (import.meta as any)?.env?.PUBLIC_SITE_URL || '';
const ogImagePath = `/og/blog/${post.slug}.png`;
const ogImageUrl = siteOrigin ? `${siteOrigin}${ogImagePath}` : ogImagePath;

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(date);
};

const categorySymbols = {
  'cloud-security': '[SEC]',
  'ctf-writeups': '[CTF]',
  'tutorials': '[TUT]',
  'rants': '[RNT]'
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="675" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />
  </Fragment>
  <article class="blog-article">
    <div class="terminal-window">
      <!-- Post Header -->
      <header class="post-header">
        <div class="post-meta">
          <span class="post-category">{categorySymbols[category]}</span>
          <time datetime={date.toISOString()} class="post-date">
            {formatDate(date)}
          </time>
          <span class="post-reading-time">{readTime} min read</span>
        </div>

        <h1 class="post-title">{title}</h1>

        <p class="post-description">{description}</p>

        <div class="post-author-tags">
          <span class="post-author">
            By <strong>{author}</strong>
          </span>

          <nav class="post-tags" aria-label="Post tags">
            {tags.map((tag) => (
              <a href={`/blog/tags/${tag}`} class="post-tag">#{tag}</a>
            ))}
          </nav>
        </div>
      </header>

      <hr class="post-divider" aria-hidden="true" />

      <!-- Post Content -->
      <div class="prose prose-terminal">
        <slot />
      </div>

      <!-- Post Footer -->
      <footer class="post-footer">
        <nav class="post-nav">
          <a href="/blog" class="back-link">
            ← Back to all posts
          </a>
        </nav>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  /* Blog article container */
  .blog-article {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  @media (min-width: 640px) {
    .blog-article {
      padding: 3rem 1.5rem;
    }
  }

  /* Post header */
  .post-header {
    margin-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    color: var(--color-primary-muted);
  }

  .post-category {
    color: var(--color-accent);
    font-weight: 700;
  }

  .post-title {
    font-size: 1.875rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  @media (min-width: 640px) {
    .post-title {
      font-size: 2.25rem;
    }
  }

  .post-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-primary-muted);
    margin-bottom: 1.5rem;
  }

  .post-author-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    font-size: 0.875rem;
  }

  .post-author {
    color: var(--color-primary-muted);
  }

  .post-author strong {
    color: var(--color-primary);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-tag {
    color: var(--color-primary-subtle);
    text-decoration: none;
    font-size: 0.75rem;
  }

  .post-tag:hover {
    color: var(--color-primary);
  }

  /* Divider */
  .post-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  /* Prose terminal styles - only terminal-specific overrides */
  .prose-terminal {
    max-width: none;
  }

  .prose-terminal h2::before {
    content: '## ';
    color: var(--color-accent);
  }

  .prose-terminal h3::before {
    content: '### ';
    color: var(--color-accent);
  }

  .prose-terminal h4::before {
    content: '#### ';
    color: var(--color-accent);
  }

  .prose-terminal pre code {
    background: transparent;
    border: none;
    padding: 0;
  }

  /* Post footer */
  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    color: var(--color-primary-muted);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .back-link:hover {
    color: var(--color-primary);
  }
</style>
